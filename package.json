{
  "name": "pandora",
  "version": "0.0.0",
  "main": "dist/electron/main.js",
  "description": "Diploma project",
  "author": {
    "name": "Vladislav",
    "email": "vladgolovko20062018@gmail.com"
  },
  "build": {
    "appId": "com.diploma.pandora",
    "productName": "Pandora",
    "files": [
      "dist/**/*"
    ]
  },
  "scripts": {
    "build:angular": "ng build",
    "build:electron": "tsc -p electron/ && yarn run build:angular",
    "electron:start": "yarn run build:electron && electron \"dist/electron/main.js\"",
    "electron:app": "yarn run build:electron && electron-builder -w",
    "start:angular": "yarn run build:angular && ng serve",
    "start:electron": "yarn run electron:start"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@angular/cdk": "^21.2.2",
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@materia-ui/ngx-monaco-editor": "^6.0.0",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/entity": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.0.3",
    "axios": "^1.15.0",
    "electron-store": "8.2.0",
    "http-methods-enum": "^0.1.1",
    "iconv-lite": "^0.7.1",
    "js-yaml": "^4.1.1",
    "lodash": "^4.18.1",
    "lodash.isequal": "^4.5.0",
    "monaco-editor": "^0.55.1",
    "ngrx": "^0.0.1-security",
    "ngx-monaco-editor": "^12.0.0",
    "ngx-monaco-editor-v2": "^21.1.4",
    "path": "^0.12.7",
    "rxjs": "~7.8.0",
    "tsc": "^2.0.4",
    "tslib": "^2.3.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@ngrx/eslint-plugin": "^21.0.1",
    "@ngrx/operators": "^21.0.1",
    "@types/js-yaml": "^4.0.9",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^27.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
