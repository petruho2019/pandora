{
  "name": "pandora",
  "version": "0.0.0",
  "main": "electron/src/dist/main.js",
  "scripts": {
    "electron:start": "yarn run electron:build && electron \"dist/electron/main.js\"",
    "electron:build": "tsc -p electron/",
    "start:angular": "ng build && ng serve",
    "start:electron": "ng build --base-href ./ && yarn run electron:start"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/cdk": "^21.0.5",
    "@angular/common": "^21.0.6",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.6",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@ngrx/effects": "^21.0.1",
    "@ngrx/entity": "^21.0.1",
    "@ngrx/store": "^21.0.1",
    "@ngrx/store-devtools": "^21.0.1",
    "@types/node": "^25.0.3",
    "electron": "^39.2.7",
    "electron-store": "8.2.0",
    "http-methods-enum": "^0.1.1",
    "iconv-lite": "^0.7.1",
    "js-yaml": "^4.1.1",
    "ngrx": "^0.0.1-security",
    "path": "^0.12.7",
    "rxjs": "~7.8.0",
    "tsc": "^2.0.4",
    "tslib": "^2.3.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@ngrx/eslint-plugin": "^21.0.1",
    "@ngrx/operators": "^21.0.1",
    "@types/js-yaml": "^4.0.9",
    "jsdom": "^27.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
